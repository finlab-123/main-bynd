# Professional .htaccess for Unlocking Access and Clean URLs
# Enable mod_rewrite for pretty URLs and access control
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Redirect index.html to root
    RewriteCond %{THE_REQUEST} /index\.html [NC]
    RewriteRule ^(.*)index\.html$ /$1 [R=301,L]

    # Remove trailing slashes (optional, for consistency)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [R=301,L]

    # Allow access to all files and folders
    RewriteRule ^ - [L]
</IfModule>

# Set proper permissions and MIME types
<FilesMatch ".*">
    Require all granted
    # Force UTF-8 encoding
    AddDefaultCharset UTF-8
</FilesMatch>

# Prevent directory listing for security
Options -Indexes

# Handle 403 Forbidden errors with a custom message or redirect (optional)
ErrorDocument 403 /index.html

# Enable CORS if needed (uncomment if required)
# Header set Access-Control-Allow-Origin "*"
